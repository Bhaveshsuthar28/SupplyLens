# ──────────────────────────────────────────────
#  SupplyLens  –  .env.example  (commit this, NOT .env)
# ──────────────────────────────────────────────

# --- MySQL (Aiven or any MySQL host) ---
DB_HOST=your-mysql-host
DB_PORT=3306
DB_NAME=your_database
DB_USER=your_user
DB_PASSWORD=your_password
DB_SSL_MODE=REQUIRED

DATABASE_URL=mysql+pymysql://user:password@host:port/dbname

# --- Application ---
# development | production
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True

# --- Security ---
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=your-secret-key-min-64-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Clerk ---
# Development keys start with pk_test_ / sk_test_
# Production keys start with pk_live_ / sk_live_
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Found in Clerk Dashboard → API Keys → Advanced
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json

# --- CORS ---
# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Email / SMTP (Brevo) ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_login_email
SMTP_PASS=your_brevo_smtp_key
MAIL_DEFAULT_FROM=your_verified_brevo_sender@example.com
MAIL_ALERT_RECIPIENT=           # leave blank to send to the uploading user's email
